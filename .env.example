# ============================================================
# NestScore Environment Variables
# Copy this file to .env and fill in all values.
# The application will REFUSE TO START if any required variable is missing.
# NEVER commit the .env file to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://nestscore_user:CHANGE_ME@localhost:5432/nestscore

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Secrets (generate with: python -c "import secrets; print(secrets.token_hex(64))") ---
SECRET_KEY=CHANGE_ME_MINIMUM_64_CHARACTERS_RANDOM_STRING_HERE_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FINGERPRINT_SALT=CHANGE_ME_MINIMUM_32_CHARACTERS_RANDOM_STRING_HERE_XXXXXXXXXX
IP_HASH_SALT=CHANGE_ME_MINIMUM_32_CHARACTERS_RANDOM_STRING_HERE_XXXXXXXXXX

# --- Google Gemini AI --- REMOVED: AI scoring has been disabled. This variable is no longer required.
# GEMINI_API_KEY=your-google-ai-studio-api-key-here

# --- Cloudflare Turnstile ---
CLOUDFLARE_TURNSTILE_SITE_KEY=your-turnstile-site-key-here
CLOUDFLARE_TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here

# --- Resend Email ---
RESEND_API_KEY=your-resend-api-key-here

# --- Admin ---
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$CHANGE_ME_BCRYPT_HASH_OF_YOUR_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=CHANGE_ME_MINIMUM_64_CHARACTERS_RANDOM_STRING_HERE_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Change this to a non-obvious path in production, e.g. /manage-c7f2a9b1
ADMIN_PATH=/manage
# Comma-separated IP addresses or CIDR ranges allowed to access the admin panel (VPN IPs)
ADMIN_IP_ALLOWLIST=127.0.0.1,::1

# --- Admin Alert Email ---
# The admin Proton Mail address for anomaly alerts (never displayed publicly)
ADMIN_ALERT_EMAIL=your-admin-email@proton.me

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key-here
NEXT_PUBLIC_ADS_ENABLED=false
